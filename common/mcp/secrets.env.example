# Copy to secrets.env (gitignored) and fill in real values.
#
# The single store for MCP credentials. Every harness now resolves secrets at
# launch from the environment rather than having them baked into its config:
#   - `pok sync` writes ${VAR} placeholders (never raw values) into each config
#   - your shell exports these, so the placeholders resolve when a harness starts
#
# Source it from your shell so the vars are present:
#   set -a; source ~/Repos/djgrant/agentkit/common/mcp/secrets.env; set +a
#
# GITHUB_TOKEN authenticates the hosted GitHub MCP server via a Bearer header
# (its OAuth flow needs dynamic client registration, which the endpoint lacks).

CONTEXT7_API_KEY=
GITHUB_TOKEN=
