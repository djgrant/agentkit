# Copy to secrets.env (gitignored) and fill in real values.
#
# This is the single store for MCP credentials. Two consumers read it:
#   1. mcp_sync.py       — expands ${VAR} when rendering ~/.claude.json
#   2. your shell profile — `source` it so OpenCode's {env:VAR} resolves too
#
# In ~/.zshrc:  set -a; source ~/Repos/djgrant/agentkit/common/mcp/secrets.env; set +a

CONTEXT7_API_KEY=
GITHUB_TOKEN=
