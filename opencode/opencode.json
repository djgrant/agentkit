{
  "model": "{env:OPENCODE_BUILD_MODEL}",
  "autoupdate": true,
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow"
    },
    "skill": "allow",
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": "ask"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "{env:OPENCODE_BUILD_MODEL}"
    },
    "plan": {
      "mode": "primary",
      "model": "{env:OPENCODE_PLAN_MODEL}"
    },
    "distill": {
      "model": "{env:OPENCODE_PLAN_MODEL}"
    },
    "orchestrate": {
      "model": "{env:OPENCODE_PLAN_MODEL}"
    },
    "architect": {
      "model": "{env:OPENCODE_PLAN_MODEL}"
    },
    "critique": {
      "model": "{env:OPENCODE_PLAN_MODEL}"
    },
    "diverge": {
      "model": "{env:OPENCODE_CREATIVE_MODEL}"
    },
    "ux": {
      "model": "{env:OPENCODE_CREATIVE_MODEL}"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true
    }
  },
  "$schema": "https://opencode.ai/config.json"
}
