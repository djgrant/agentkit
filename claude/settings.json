{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "SendMessage",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "disableClaudeAiConnectors": true,
  "disableBundledSkills": true,
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "disableArtifact": true,
  "statusLine": {
    "type": "command",
    "command": "bun $HOME/.claude/scripts/statusline/src/index.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "plannotator@plannotator": true,
    "swift-lsp@claude-plugins-official": true,
    "humans@humans-sh": true
  },
  "extraKnownMarketplaces": {
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "humans-sh": {
      "source": {
        "source": "directory",
        "path": "$HOME/Repos/djgrant/humans.sh"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "low",
  "skipDangerousModePermissionPrompt": true
}
